# Auto DM backend — exclude from Docker build context.
# Keeps the image lean and prevents leaking secrets.

# Secrets and local config
.env
.env.local
*.env
config.json

# Git metadata
.git
.gitignore
.gitattributes

# Tests + caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
tests/

# Python build artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/

# Virtual envs
.venv/
venv/
env/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Docs (not needed in image)
*.md
!src/auto_dm/**/*.md
# Exception: PHB rulebook content MUST ship in the image — the engine
# loads it at startup to populate races, classes, spells, etc. Without
# these, /api/character-options returns 500 because get_race() → None.
!data/phb/**/*.md

# Local saves (mounted at runtime if needed)
saves/

# Docker-specific files (avoid recursion)
Dockerfile
docker-compose.yml
.dockerignore
DEPLOY.md