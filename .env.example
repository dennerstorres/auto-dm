# =====================================================
# Auto DM — runtime
# =====================================================
JWT_SECRET=
DATABASE_URL=postgresql+asyncpg://auto_dm:auto_dm@localhost:5432/auto_dm
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:14004
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# O cadastro é sempre aberto. Um convite válido permite usar a chave global;
# sem convite, a conta fica restrita ao BYOK.
INVITE_CODE=

# =====================================================
# Provider global — usado apenas por contas autorizadas
# =====================================================
AUTO_DM_PROVIDER=minimax
AUTO_DM_API_KEY=
AUTO_DM_MODEL=MiniMax-Text-01
AUTO_DM_BASE_URL=
AUTO_DM_TEMPERATURE=0.8
AUTO_DM_MAX_TOKENS=8192

# Chaves individuais abaixo são mantidas para ferramentas legadas e scripts.
# O backend web usa AUTO_DM_* para a chave global e credenciais criptografadas
# no banco para BYOK.

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Minimax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=

# =====================================================
# Phase 51 — BYOK (multi-provider, BYOK por usuário)
# =====================================================
# Quando AUTO_DM_BYOK_ENABLED=1, usuários podem cadastrar a própria
# chave de API em Preferências → IA. Com a flag off (default), as
# rotas de credencial retornam 403. Contas sem convite exigem BYOK e,
# portanto, não conseguem usar LLM enquanto a flag estiver desligada.
AUTO_DM_BYOK_ENABLED=

# Chave mestra para cifrar as credenciais BYOK no banco. Formato:
# "VERSÃO:<fernet_key>[,VERSÃO:<fernet_key>]" — a primeira entrada cifra
# novas credenciais; todas decifram (rotação sem downtime).
# Gere com o Python do ambiente virtual e prefixe a versão, por exemplo:
# .\.venv\Scripts\python.exe -c "from cryptography.fernet import Fernet; print('1:' + Fernet.generate_key().decode())"
AUTO_DM_CREDENTIALS_KEY=
